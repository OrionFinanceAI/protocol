{
  "name": "@orion-finance/protocol",
  "description": "Orion Finance Protocol",
  "version": "2.3.5",
  "type": "module",
  "engines": {
    "node": ">=22.10.0"
  },
  "author": {
    "name": "Orion Finance",
    "url": "https://github.com/OrionFinanceAI"
  },
  "scripts": {
    "build": "pnpm clean && cross-env TS_NODE_TRANSPILE_ONLY=true hardhat build",
    "build:sepolia": "pnpm clean && cross-env TS_NODE_TRANSPILE_ONLY=true hardhat compile --network sepolia",
    "clean": "rimraf ./artifacts ./cache ./types",
    "compile": "cross-env TS_NODE_TRANSPILE_ONLY=true hardhat compile",
    "compile:sepolia": "cross-env TS_NODE_TRANSPILE_ONLY=true hardhat compile --network sepolia",
    "deploy:sepolia": "hardhat run protocol-ops/deploy.ts --network sepolia",
    "lint": "pnpm lint:sol && pnpm lint:ts && pnpm prettier:check",
    "lint:sol": "solhint --noPoster --max-warnings 20 \"contracts/**/*.sol\"",
    "lint:ts": "eslint --ext .js,.ts .",
    "typechain:generate": "pnpm compile",
    "typechain": "pnpm typechain:generate",
    "test:fuzz": "hardhat test solidity",
    "test:no-fork": "cross-env FORK_MAINNET=false hardhat test",
    "test:fork": "sh -c 'set -a; [ -f .env ] && source .env; set +a; if [ -z \"$MAINNET_RPC_URL\" ]; then echo \"Skipping fork tests: MAINNET_RPC_URL is not set\"; exit 0; fi; FORK_MAINNET=true hardhat test --network hardhat test/crossAsset/ChainlinkPriceAdapter.test.ts test/crossAsset/ERC4626PriceAdapter.test.ts test/crossAsset/ERC4626ExecutionAdapter.test.ts test/crossAsset/MorphoBlueSupplyVault.test.ts'",
    "test": "pnpm test:no-fork && pnpm test:fork",
    "test:sepolia": "hardhat test --network sepolia",
    "docgen": "cross-env TS_NODE_TRANSPILE_ONLY=true hardhat compile && node scripts/run-docgen.mjs",
    "prettier:check": "prettier --check \"**/*.{js,json,md,sol,ts,yml}\"",
    "prettier:write": "prettier --write \"**/*.{js,json,md,sol,ts,yml}\"",
    "slither": "bash scripts/run-slither.sh",
    "verify:vault": "hardhat run protocol-ops/verify-vault.ts --network sepolia",
    "storage-layout": "hardhat run scripts/check-storage-layout.ts"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@fhevm/hardhat-plugin": "^0.4.2",
    "@fhevm/mock-utils": "0.4.2",
    "@nomicfoundation/hardhat-ethers": "^4.0.10",
    "@nomicfoundation/hardhat-ethers-chai-matchers": "^3.0.7",
    "@nomicfoundation/hardhat-ignition": "^3.1.4",
    "@nomicfoundation/hardhat-ignition-ethers": "^3.1.4",
    "@nomicfoundation/hardhat-keystore": "^3.0.8",
    "@nomicfoundation/hardhat-mocha": "^3.0.18",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.7",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.3",
    "@nomicfoundation/hardhat-typechain": "^3.0.8",
    "@nomicfoundation/hardhat-verify": "^3.0.16",
    "@nomicfoundation/ignition-core": "^3.1.4",
    "@openzeppelin/hardhat-upgrades": "^3.9.1",
    "@typechain/ethers-v6": "^0.5.1",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@zama-fhe/oracle-solidity": "^0.2.0",
    "@zama-fhe/relayer-sdk": "^0.4.2",
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "ethers": "^6.15.0",
    "hardhat": "^3.4.3",
    "hardhat-deploy": "^2.0.5",
    "mocha": "^11.7.1",
    "prettier": "^3.8.3",
    "prettier-plugin-solidity": "^2.3.1",
    "rimraf": "^6.1.3",
    "solhint": "^6.2.1",
    "solhint-plugin-prettier": "^0.1.0",
    "solidity-docgen": "0.6.0-beta.36",
    "ts-generator": "^0.1.1",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@chainlink/contracts": "^1.4.0",
    "@fhevm/solidity": "^0.11.1",
    "@morpho-org/morpho-blue": "^1.0.0",
    "@openzeppelin/contracts": "^5.6.1",
    "@openzeppelin/contracts-upgradeable": "^5.6.1",
    "@uniswap/v3-core": "1.0.2-solc-0.8-simulate",
    "@uniswap/v3-periphery": "^1.4.4",
    "encrypted-types": "^0.0.4"
  },
  "pnpm": {
    "overrides": {
      "@openzeppelin/contracts-upgradeable@>=4.3.0 <4.8.3": "^4.9.6",
      "@openzeppelin/contracts@>=4.3.0 <4.8.3": "^4.9.6",
      "lodash": "^4.17.21"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "@nomicfoundation/hardhat-ethers",
        "@nomicfoundation/hardhat-verify",
        "@nomicfoundation/hardhat-network-helpers"
      ],
      "allowedVersions": {
        "hardhat": "^3.0.0",
        "chai": "6.x",
        "ethers": "6.x",
        "@typechain/ethers-v6": "0.x"
      }
    },
    "allowedDeprecatedVersions": {
      "glob": "*",
      "inflight": "*",
      "rimraf": "*",
      "@types/minimatch": "*",
      "lodash.isequal": "*",
      "zksync-web3": "*"
    }
  }
}
